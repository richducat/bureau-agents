# Public application addresses. The production values will be set in Namecheap cPanel.
NODE_ENV=development
PORT=8787
APP_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:8787
ALLOWED_ORIGINS=http://localhost:5173

# Namecheap MySQL database (never commit real values).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=bureau_app
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=bureau
MYSQL_SSL=false

# Generate with: openssl rand -hex 32
CSRF_SECRET=replace-with-at-least-32-random-characters
# Generate a 32-byte hex key with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=replace-with-64-hex-characters
SESSION_COOKIE_NAME=bureau_session
SESSION_TTL_DAYS=30

# Stripe marketplace keys and webhook secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_OPERATOR_PRO=
STRIPE_PRICE_CLIENT_SCALE=
STRIPE_PRICE_VERIFIED_AGENT=

# SMTP credentials for transactional email (Namecheap mailbox is supported).
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Bureau <hello@example.com>

# Comma-separated emails that receive the platform admin role.
ADMIN_EMAILS=

# Frontend build configuration. These values are public by design.
VITE_API_BASE_URL=http://localhost:8787/api
VITE_SITE_URL=http://localhost:5173
VITE_GA4_MEASUREMENT_ID=
